<Application x:Class="LeadStoreAutoBot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:h="clr-namespace:LeadStoreAutoBot.Helpers"
            >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI Fluent (Win11) -->
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>

                <!-- Наши кисти и стили -->
                <ResourceDictionary Source="Themes/DefaultBrushes.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры -->
            <h:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <h:BoolToVisibilityConverter x:Key="BoolToVisInverse" Inverse="True"/>
            <h:InverseBoolConverter x:Key="InverseBool"/>
            <h:StatusToBrushConverter x:Key="StatusToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<UserControl x:Class="LeadStoreAutoBot.Views.TableTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:LeadStoreAutoBot.ViewModels"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Тулбар -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <ui:Button Content="📥 Загрузить из Sheets" Appearance="Primary"
                       Command="{Binding LoadFromSheetsCommand}"
                       Padding="14,6" Margin="0,0,8,0"
                       IsEnabled="{Binding UseManualTable, Converter={StaticResource InverseBool}}"/>
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource MutedText}"
                       Text="⏳ загрузка..." Margin="0,0,12,0"
                       Visibility="{Binding IsLoadingSheet, Converter={StaticResource BoolToVis}}"/>
            <ui:Button Content="📋 Вставить (Ctrl+V)"
                       Click="Paste_Click"
                       Padding="14,6" Margin="0,0,8,0"/>
            <ui:Button Content="🗑 Очистить" Appearance="Danger"
                       Command="{Binding ClearRecordsCommand}"
                       Padding="14,6"/>
        </StackPanel>

        <!-- Легенда -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Border Background="#1a3a1a" CornerRadius="3" Padding="8,2" Margin="0,0,6,0">
                <TextBlock Text="✓ Создан" FontSize="11" Foreground="#e6edf3"/>
            </Border>
            <Border Background="#3a1a1a" CornerRadius="3" Padding="8,2" Margin="0,0,6,0">
                <TextBlock Text="✗ Ошибка" FontSize="11" Foreground="#e6edf3"/>
            </Border>
            <Border Background="#2a2a00" CornerRadius="3" Padding="8,2" Margin="0,0,6,0">
                <TextBlock Text="→ Активен" FontSize="11" Foreground="#e6edf3"/>
            </Border>
            <Border Background="#3a1a2a" CornerRadius="3" Padding="8,2" Margin="0,0,6,0">
                <TextBlock Text="⏭ Дубль" FontSize="11" Foreground="#e6edf3"/>
            </Border>
            <Border Background="{DynamicResource Bg3Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,2">
                <TextBlock Text="○ Ожидает" FontSize="11" Foreground="{DynamicResource Text2Brush}"/>
            </Border>
        </StackPanel>

        <!-- Таблица -->
        <Border Grid.Row="2" Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8">
            <DataGrid x:Name="Grid"
                      ItemsSource="{Binding Records}"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      Foreground="{DynamicResource TextBrush}"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="All"
                      RowHeight="26"
                      ColumnHeaderHeight="34"
                      SelectionUnit="CellOrRowHeader"
                      SelectionMode="Extended"
                      ClipboardCopyMode="ExcludeHeader"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="False"
                      KeyboardNavigation.TabNavigation="Continue"
                      PreviewKeyDown="Grid_PreviewKeyDown"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Resources>
                    <!-- Подсветка ячейки фоном по статусу.
                         Красим именно ячейки (а не DataGridRow), потому что WPF-UI
                         ControlsDictionary подменяет Template DataGridRow и наши
                         DataTrigger'ы на Row.Background не пробиваются. -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="ok">
                                <Setter Property="Background" Value="#1a3a1a"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="err">
                                <Setter Property="Background" Value="#3a1a1a"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="active">
                                <Setter Property="Background" Value="#3a3a00"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="skip">
                                <Setter Property="Background" Value="#3a1a2a"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="dup">
                                <Setter Property="Background" Value="#3a1a2a"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="no_site">
                                <Setter Property="Background" Value="#1a2a3a"/>
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <!-- Строка — прозрачная, чтобы ячейки были видны. -->
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№"     Binding="{Binding RowNum}" Width="55" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Сайт"   Binding="{Binding Site, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Тел. О" Binding="{Binding Op,   UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                    <DataGridTextColumn Header="Тел. М" Binding="{Binding Mg,   UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Подсказка -->
        <TextBlock Grid.Row="3" Style="{StaticResource MutedText}" Margin="2,8,0,0"
                   Text="💡 Двойной клик по ячейке — редактирование. Ctrl+V — вставить из Excel/Sheets. Delete — очистить выделенное. Снизу всегда есть пустые строки — просто кликай и пиши."/>
    </Grid>
</UserControl>

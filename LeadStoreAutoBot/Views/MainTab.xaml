<UserControl x:Class="LeadStoreAutoBot.Views.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:LeadStoreAutoBot.ViewModels"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка со статистикой -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,6,0" Grid.Column="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Создано"/>
                    <TextBlock Text="{Binding StatCreated}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,6,0" Grid.Column="1">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Пропущено"/>
                    <TextBlock Text="{Binding StatSkipped}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource YellowBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,6,0" Grid.Column="2">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Ошибок"/>
                    <TextBlock Text="{Binding StatErrors}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource RedBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,0,0" Grid.Column="3">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Text="Время"/>
                    <TextBlock Text="{Binding TimerText}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Accent2Brush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Консоль -->
        <Border Grid.Row="1" Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource Bg3Brush}"
                        Padding="10,6" CornerRadius="8,8,0,0">
                    <Grid>
                        <TextBlock Style="{StaticResource HeaderText}" Text="📜 Лог"
                                   HorizontalAlignment="Left"/>
                        <ui:Button Content="🔍 Найти (Ctrl+F)" Padding="10,3"
                                   HorizontalAlignment="Right"
                                   Click="ToggleSearch_Click"/>
                    </Grid>
                </Border>

                <!-- Панель поиска (скрыта по умолчанию) -->
                <Border Grid.Row="1" x:Name="SearchPanel"
                        Background="{DynamicResource Bg2Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="SearchBox"
                                 Tag="🔍 поиск по логу..."
                                 KeyDown="SearchBox_KeyDown"
                                 TextChanged="SearchBox_TextChanged"/>
                        <ui:Button Grid.Column="2" Content="↑" Padding="10,4"
                                   ToolTip="Предыдущее (Shift+Enter)"
                                   Click="FindPrev_Click"/>
                        <ui:Button Grid.Column="4" Content="↓" Padding="10,4"
                                   ToolTip="Следующее (Enter)"
                                   Click="FindNext_Click"/>
                        <ui:Button Grid.Column="6" Content="✕" Padding="10,4"
                                   ToolTip="Закрыть (Esc)"
                                   Click="CloseSearch_Click"/>
                    </Grid>
                </Border>

                <!-- Лог + плавающая кнопка «вниз» (как в Telegram). -->
                <Grid Grid.Row="2">
                    <RichTextBox x:Name="LogBox"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 Padding="10"/>

                    <!-- Кнопка-стрелка, появляется только когда пользователь отмотал вверх
                         и лог ушёл дальше вниз. Клик — прыгнуть к последнему сообщению. -->
                    <Button x:Name="ScrollToEndButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,18,14"
                            Width="40" Height="40"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="ScrollToEndButton_Click"
                            ToolTip="Прокрутить вниз">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse x:Name="Bg"
                                             Fill="{DynamicResource AccentBrush}"
                                             Opacity="0.92">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                              Color="Black" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="▼"
                                               Foreground="#0d1117"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Прогресс-бар + статус + ETA -->
        <Grid Grid.Row="2" Margin="0,12,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0" Height="6" Value="{Binding ProgressValue}" Maximum="100"
                         Background="{DynamicResource Bg3Brush}"
                         Foreground="{DynamicResource AccentBrush}"
                         BorderThickness="0"/>
            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource MutedText}"
                           Text="{Binding StatusText}"/>
                <TextBlock Grid.Column="1" Style="{StaticResource MutedText}"
                           Text="{Binding EtaText}"
                           Foreground="{DynamicResource Accent2Brush}"
                           FontWeight="SemiBold"/>
            </Grid>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="⏵ ЗАПУСТИТЬ" Appearance="Primary"
                       Command="{Binding StartCommand}"
                       Padding="20,8" Margin="0,0,8,0"
                       IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}"/>
            <ui:Button Command="{Binding PauseCommand}"
                       Padding="16,8" Margin="0,0,8,0"
                       IsEnabled="{Binding IsRunning}">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Content" Value="⏸ ПАУЗА"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                <Setter Property="Content" Value="▶ ПРОДОЛЖИТЬ"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ui:Button Content="⏹ СТОП" Appearance="Danger"
                       Command="{Binding StopCommand}"
                       Padding="16,8"
                       IsEnabled="{Binding IsRunning}"/>
        </StackPanel>
    </Grid>
</UserControl>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Базовые TextBlock / Label -->
    <Style TargetType="TextBlock" x:Key="BodyText">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
        <Setter Property="FontSize"   Value="{DynamicResource UiFontSize}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}"/>

    <Style TargetType="TextBlock" x:Key="HeaderText" BasedOn="{StaticResource BodyText}">
        <Setter Property="FontSize"   Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="MutedText" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
    </Style>

    <!-- Карточка-секция (на левой панели) -->
    <Style TargetType="Border" x:Key="Card">
        <Setter Property="Background"      Value="{DynamicResource Bg2Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="12"/>
        <Setter Property="Margin"          Value="0,0,0,10"/>
    </Style>

    <!-- Заголовок раздела справки (с подчёркиванием акцентом) -->
    <Style TargetType="Border" x:Key="HelpSectionHeaderUnderline">
        <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Height"          Value="2"/>
        <Setter Property="Margin"          Value="0,2,0,12"/>
    </Style>

    <!-- Карточка-шага (номер + заголовок + текст) -->
    <Style TargetType="Border" x:Key="HelpStepCard" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style TargetType="Border" x:Key="HelpStepBadge">
        <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="CornerRadius"    Value="3"/>
        <Setter Property="Padding"         Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Вкладка-радиокнопка (выглядит как кликабельный таб) -->
    <Style TargetType="RadioButton" x:Key="TabRadio">
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="GroupName" Value="MainTabs"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="14,7"
                            Margin="2,0">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg3Brush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="#0d1117"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

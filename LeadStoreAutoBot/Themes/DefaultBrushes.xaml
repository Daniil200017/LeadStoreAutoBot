<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Дефолтная (тёмная) тема — перезаписывается ThemeService.Apply в рантайме. -->
    <SolidColorBrush x:Key="BgBrush"      Color="#0d1117"/>
    <SolidColorBrush x:Key="Bg2Brush"     Color="#161b22"/>
    <SolidColorBrush x:Key="Bg3Brush"     Color="#21262d"/>
    <SolidColorBrush x:Key="TextBrush"    Color="#e6edf3"/>
    <SolidColorBrush x:Key="Text2Brush"   Color="#8b949e"/>
    <SolidColorBrush x:Key="BorderBrush"  Color="#30363d"/>
    <SolidColorBrush x:Key="AccentBrush"  Color="#00d4aa"/>
    <SolidColorBrush x:Key="Accent2Brush" Color="#0099ff"/>
    <SolidColorBrush x:Key="RedBrush"     Color="#ff4757"/>
    <SolidColorBrush x:Key="YellowBrush"  Color="#ffd32a"/>

    <sys:Boolean x:Key="IsDark">True</sys:Boolean>

    <!-- Базовая типографика -->
    <FontFamily x:Key="UiFont">Segoe UI</FontFamily>
    <sys:Double x:Key="UiFontSize">13</sys:Double>

</ResourceDictionary>
